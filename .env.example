# Copia este archivo a ".env" y rellena con las claves de tu proyecto Supabase.
# Las encuentras en:  Supabase → Project Settings → API
#
# IMPORTANTE: solo se usa la clave "anon public". Nunca pongas aquí la "service_role".

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLIC
